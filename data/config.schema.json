{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.armazemautopecas.com.br/config.schema.gasolina.json",
  "title": "LP Config — Gasolina",
  "description": "Schema dos config.json de cada LP veículo-cêntrica (gasolina). Sem OEM/peça/fornecedor/placa. Skill lp-armazem-lifans gera arquivos compatíveis.",
  "type": "object",
  "required": [
    "slug",
    "veiculo",
    "hero",
    "wa",
    "why",
    "final_cta",
    "seo"
  ],
  "additionalProperties": true,
  "properties": {
    "_doc": { "type": "string" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },

    "veiculo": {
      "type": "object",
      "required": ["marca", "modelo"],
      "properties": {
        "marca": { "type": "string" },
        "modelo": { "type": "string" },
        "posicionamento": { "type": "string" }
      }
    },

    "hero": {
      "type": "object",
      "required": ["foto_static", "eyebrow", "h1_linha1", "h1_linha2", "h1_sub", "sub", "cta_mobile_label"],
      "properties": {
        "foto_static": { "type": "string" },
        "foto_dust": { "type": "string" },
        "eyebrow": { "type": "string" },
        "h1_linha1": { "type": "string" },
        "h1_linha2": { "type": "string" },
        "h1_sub": { "type": "string" },
        "sub": { "type": "string" },
        "cta_mobile_label": { "type": "string" },
        "cta_desktop_label": { "type": "string" },
        "trusts": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "string" },
          "description": "3 selos curtos UPPERCASE no Hero (ex: ATENDIMENTO HUMANO, ENTREGA RASTREADA, FRETE PRA TODO BRASIL). Sem CONSULTA POR PLACA (não tem busca nessa LP)."
        }
      }
    },

    "trust_bar": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["icon", "ttl", "sub", "num"],
            "properties": {
              "icon": { "type": "string", "enum": ["shield", "box", "gear", "factory"] },
              "ttl": { "type": "string" },
              "sub": { "type": "string" },
              "num": { "type": "string" }
            }
          }
        }
      }
    },

    "why": {
      "type": "object",
      "required": ["h2_l1", "h2_l2", "h2_l2_red", "items"],
      "properties": {
        "h2_l1": { "type": "string" },
        "h2_l2": { "type": "string" },
        "h2_l2_red": { "type": "string" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["num", "ttl", "body"],
            "properties": {
              "num": { "type": "string" },
              "ttl": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        }
      }
    },

    "categorias": {
      "type": "object",
      "required": ["titulo", "items"],
      "properties": {
        "eyebrow": { "type": "string" },
        "titulo": { "type": "string" },
        "subtitulo": { "type": "string" },
        "cta_final": { "type": "string" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["nome", "whatsapp_mensagem"],
            "properties": {
              "slug": { "type": "string" },
              "nome": { "type": "string" },
              "emoji": { "type": "string" },
              "imagem": { "type": "string", "description": "Nome do arquivo dentro de assets/ (ex: filtros.webp). Vazio = usa emoji fallback." },
              "descricao": { "type": "string" },
              "cta_label": { "type": "string" },
              "whatsapp_mensagem": { "type": "string" }
            }
          }
        }
      }
    },

    "wa": {
      "type": "object",
      "required": ["hero_link", "fab_default", "final_cta"],
      "properties": {
        "hero_link": { "type": "string" },
        "fab_default": { "type": "string" },
        "categorias_geral": { "type": "string" },
        "final_cta": { "type": "string" }
      }
    },

    "final_cta": {
      "type": "object",
      "required": ["h2_l1", "h2_l2_red_l1", "h2_l2_red_l2", "sub_pre", "sub_post", "btn", "microtext_pre", "microtext_post"],
      "properties": {
        "h2_l1": { "type": "string" },
        "h2_l2_red_l1": { "type": "string" },
        "h2_l2_red_l2": { "type": "string" },
        "sub_pre": { "type": "string" },
        "sub_post": { "type": "string" },
        "btn": { "type": "string" },
        "microtext_pre": { "type": "string" },
        "microtext_post": { "type": "string" }
      }
    },

    "testimonials": {
      "type": "object",
      "properties": {
        "h2_l1": { "type": "string" },
        "h2_l2": { "type": "string" }
      }
    },

    "content": {
      "type": "object",
      "properties": {
        "testimonials": { "type": "array" },
        "faqs": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "q": { "type": "string" },
              "a": { "type": "string" }
            }
          }
        }
      }
    },

    "seo": {
      "type": "object",
      "required": ["title", "description", "og_image", "og_image_alt", "twitter_description", "canonical_path"],
      "properties": {
        "title": { "type": "string", "minLength": 30, "maxLength": 70 },
        "description": { "type": "string", "minLength": 80, "maxLength": 200 },
        "og_image": { "type": "string" },
        "og_image_alt": { "type": "string" },
        "twitter_description": { "type": "string" },
        "canonical_path": { "type": "string", "pattern": "^/.*/$" }
      }
    }
  }
}
